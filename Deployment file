apiVersion: apps/v1
kind: Deployment
metadata:
  name: calci-deployment
  labels:
    app: calci
spec:
  replicas: 2
  selector:
    matchLabels:
      app: calci
  template:
    metadata:
      labels:
        app: calci
    spec:
      containers:
      - name: calci
        image: poojap7026/calci1:latest
        ports:
          - containerPort: 80
